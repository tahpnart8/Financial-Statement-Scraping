{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://financial-statement-scraping.onrender.com/api/:path*"
        },
        {
            "source": "/health",
            "destination": "https://financial-statement-scraping.onrender.com/health"
        },
        {
            "source": "/((?!api|health).*)",
            "destination": "/index.html"
        }
    ]
}
